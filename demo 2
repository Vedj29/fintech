    if (st.session_state.auto_speak
            and st.session_state.chat
            and st.session_state.chat[-1]["role"] == "ai"):
        latest = st.session_state.chat[-1]["text"]
        if latest != st.session_state.get("_last_auto_spoken", ""):
            st.session_state["_last_auto_spoken"] = latest
            render_auto_speak(latest, lang)

    st.markdown("<br>", unsafe_allow_html=True)

    # ── Text input + send ──
    inp_col, btn_col = st.columns([5,1])
    ph         = T("ask_placeholder")
    user_input = inp_col.text_input("msg", placeholder=ph, label_visibility="collapsed", key="chat_msg")
    send       = btn_col.button(T("send"), use_container_width=True, type="primary")

    if send and user_input.strip():
        st.session_state.chat.append({"role":"user","text":user_input.strip()})
        resp = chat_response(uid, user_input.strip(), lang)
        st.session_state.chat.append({"role":"ai","text":resp})
        st.rerun()

    if st.session_state.chat:
        if st.button(T("clear_chat"), type="secondary"):
            st.session_state.chat              = []
            st.session_state["_last_auto_spoken"] = ""
            st.rerun()


#  MAIN ROUTER

def main():
    if not st.session_state.uid:
        page_login()
        return

    page = render_sidebar()

    if st.session_state.is_admin:
        page_admin()
        return

    if   "Dashboard"  in page: page_dashboard()
    elif "Analysis"   in page: page_analysis()
    elif "Prediction" in page: page_predictions()
    elif "Goals"      in page: page_goals()
    elif "What-If"    in page: page_whatif()
    elif "Advisor"    in page: page_chat()

if __name__ == "__main__":
    main()
    elif "Advisor"    in page: page_chat()

if __name__ == "__main__":
    main()
