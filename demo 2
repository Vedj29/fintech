def render_voice_button(lang_code="en"):
    lang_map    = {"en": "en-IN", "hi": "hi-IN", "mr": "mr-IN"}
    speech_lang = lang_map.get(lang_code, "en-IN")
    btn_label   = T("voice_btn")

    voice_html = f"""
    <div id="voiceContainer" style="margin-bottom:10px;">
        <button id="voiceBtn" onclick="toggleVoice()"
            style="display:flex;align-items:center;gap:8px;
                   padding:10px 18px;border-radius:10px;border:none;cursor:pointer;
                   background:linear-gradient(135deg,#2563eb,#7c3aed);
                   color:#ffffff;font-weight:700;font-size:13px;font-family:'Nunito',sans-serif;
                   transition:all .2s;width:100%;justify-content:center;">
            <span id="voiceIcon">🎙️</span>
            <span id="voiceBtnText">{btn_label}</span>
        </button>
        <div id="voiceStatus" style="display:none;margin-top:10px;padding:10px 14px;
             border-radius:10px;background:#fef2f2;border:1px solid #fca5a5;
             font-size:13px;color:#991b1b;font-weight:600;"></div>
        <div id="voiceResult" style="display:none;margin-top:8px;padding:10px 14px;
             border-radius:10px;background:#f0fdf4;border:1px solid #86efac;
             font-size:13px;color:#166534;font-weight:600;"></div>
    </div>

    <script>
    var recognition = null;
    var isListening = false;

    function toggleVoice() {{
        if (!('webkitSpeechRecognition' in window) && !('SpeechRecognition' in window)) {{
            document.getElementById('voiceStatus').style.display = 'block';
            document.getElementById('voiceStatus').innerText = '{T("voice_not_supported")}';
            return;
        }}
        isListening ? stopVoice() : startVoice();
    }}

    function startVoice() {{
        var SR = window.SpeechRecognition || window.webkitSpeechRecognition;
        recognition = new SR();
        recognition.lang = '{speech_lang}';
        recognition.continuous = false;
        recognition.interimResults = false;
        recognition.maxAlternatives = 1;

        recognition.onstart = function() {{
            isListening = true;
            var btn = document.getElementById('voiceBtn');
            btn.style.background = 'linear-gradient(135deg,#ef4444,#f97316)';
            document.getElementById('voiceIcon').innerText = '🔴';
            document.getElementById('voiceBtnText').innerText = '{T("voice_listening")}';
            document.getElementById('voiceStatus').style.display = 'block';
            document.getElementById('voiceStatus').innerText = '{T("voice_listening")}';
            document.getElementById('voiceResult').style.display = 'none';
        }};

        recognition.onresult = function(event) {{
            var transcript = event.results[0][0].transcript;
            document.getElementById('voiceStatus').innerText = '{T("voice_processing")}';
            document.getElementById('voiceResult').style.display = 'block';
            document.getElementById('voiceResult').innerText = '{T("voice_done")}: ' + transcript;

            // Fill Streamlit text input
            var inputs = window.parent.document.querySelectorAll('input[type="text"]');
            for (var i = 0; i < inputs.length; i++) {{
                var ph = inputs[i].placeholder || '';
                if (ph.includes('Ask') || ph.includes('पूछ') || ph.includes('विचार') || ph.includes('finances')) {{
                    var setter = Object.getOwnPropertyDescriptor(window.HTMLInputElement.prototype, 'value').set;
                    setter.call(inputs[i], transcript);
                    inputs[i].dispatchEvent(new Event('input', {{ bubbles: true }}));
                    break;
                }}
            }}
            resetBtn();
        }};

        recognition.onerror = function() {{
            document.getElementById('voiceStatus').innerText = '{T("voice_error")}';
            resetBtn();
        }};

        recognition.onend = function() {{ if (isListening) resetBtn(); }};
        recognition.start();
    }}

    function stopVoice() {{
        if (recognition) recognition.stop();
        resetBtn();
    }}

    function resetBtn() {{
        isListening = false;
        var btn = document.getElementById('voiceBtn');
        btn.style.background = 'linear-gradient(135deg,#2563eb,#7c3aed)';
        document.getElementById('voiceIcon').innerText = '🎙️';
        document.getElementById('voiceBtnText').innerText = '{btn_label}';
        setTimeout(function() {{
            document.getElementById('voiceStatus').style.display = 'none';
        }}, 3000);
    }}
    </script>
    <style>
    @keyframes pulse {{
        0%,100% {{ box-shadow: 0 0 0 0 rgba(239,68,68,.4); }}
        50%      {{ box-shadow: 0 0 0 10px rgba(239,68,68,0); }}
    }}
    </style>
    """
    st.components.v1.html(voice_html, height=140)


