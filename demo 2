#  TTS AUTO-SPEAK COMPONENT
#  Injects a hidden iframe that auto-plays the latest AI response via
#  the browser's SpeechSynthesis API. Fires once per new response.
# ══════════════════════════════════════════════════════════════════════════════

def render_auto_speak(text: str, lang_code: str):
    """Auto-speak the given text using the browser's Speech Synthesis API."""
    lang_map = {"en": "en-IN", "hi": "hi-IN", "mr": "mr-IN"}
    speech_lang = lang_map.get(lang_code, "en-IN")

    # Strip markdown formatting for cleaner speech
    import re
    clean = re.sub(r'\*+', '', text)       # remove bold/italic markers
    clean = re.sub(r'#{1,6} ', '', clean)  # remove heading markers
    clean = re.sub(r'→', 'to', clean)
    clean = re.sub(r'₹', 'rupees ', clean)
    clean = re.sub(r'\n+', '. ', clean)
    clean = clean.replace('"', '').replace("'", "").strip()
    # Escape for JS
    clean = clean.replace('\\', '\\\\').replace('`', '\\`')

    html = f"""
    <script>
    (function() {{
        var text = `{clean}`;
        var lang = '{speech_lang}';
        if (!('speechSynthesis' in window)) return;
        window.speechSynthesis.cancel();
        var u = new SpeechSynthesisUtterance(text);
        u.lang = lang;
        u.rate = 0.92;
        u.pitch = 1.0;
        u.volume = 1.0;
        // Small delay so page finishes rendering first
        setTimeout(function() {{ window.speechSynthesis.speak(u); }}, 400);
    }})();
    </script>
    """
    st.components.v1.html(html, height=0)


def render_manual_speak_button(text: str, lang_code: str, key_suffix: str = ""):
    """Render a small Speak / Stop button for each AI message."""
    lang_map = {"en": "en-IN", "hi": "hi-IN", "mr": "mr-IN"}
    speech_lang = lang_map.get(lang_code, "en-IN")

    import re
    clean = re.sub(r'\*+', '', text)
    clean = re.sub(r'#{1,6} ', '', clean)
    clean = re.sub(r'→', 'to', clean)
    clean = re.sub(r'₹', 'rupees ', clean)
    clean = re.sub(r'\n+', '. ', clean)
    clean = clean.replace('"', '').replace("'", "").strip()
    clean = clean.replace('\\', '\\\\').replace('`', '\\`')

    btn_id = f"speakBtn_{key_suffix}"
    speak_lbl = T("speak_now")
    stop_lbl  = T("stop_speak")

    html = f"""
    <button id="{btn_id}"
        onclick="toggleSpeak_{key_suffix}(this)"
        style="display:inline-flex;align-items:center;gap:4px;
               padding:4px 10px;border-radius:6px;border:1px solid #bfdbfe;
               background:#eff6ff;color:#2563eb;font-size:11px;font-weight:700;
               cursor:pointer;transition:all .2s;margin-left:6px;">
        🔊 {speak_lbl}
    </button>
    <script>
    var _speaking_{key_suffix} = false;
    var _utt_{key_suffix} = null;
    function toggleSpeak_{key_suffix}(btn) {{
        if (_speaking_{key_suffix}) {{
            window.speechSynthesis.cancel();
            _speaking_{key_suffix} = false;
            btn.innerHTML = '🔊 {speak_lbl}';
            btn.style.background = '#eff6ff';
            btn.style.borderColor = '#bfdbfe';
            btn.style.color = '#2563eb';
        }} else {{
            if (!('speechSynthesis' in window)) {{
                alert('Text-to-speech not supported in your browser.');
                return;
            }}
            window.speechSynthesis.cancel();
            _utt_{key_suffix} = new SpeechSynthesisUtterance(`{clean}`);
            _utt_{key_suffix}.lang = '{speech_lang}';
            _utt_{key_suffix}.rate = 0.92;
            _utt_{key_suffix}.pitch = 1.0;
            _utt_{key_suffix}.onend = function() {{
                _speaking_{key_suffix} = false;
                btn.innerHTML = '🔊 {speak_lbl}';
                btn.style.background = '#eff6ff';
                btn.style.borderColor = '#bfdbfe';
                btn.style.color = '#2563eb';
            }};
            window.speechSynthesis.speak(_utt_{key_suffix});
            _speaking_{key_suffix} = true;
            btn.innerHTML = '⏹ {stop_lbl}';
            btn.style.background = '#fef2f2';
            btn.style.borderColor = '#fca5a5';
            btn.style.color = '#dc2626';
        }}
    }}
    </script>
    """
    return html


